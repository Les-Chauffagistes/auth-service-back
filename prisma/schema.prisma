datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "asyncio"
  recursive_type_depth = 5
}

enum lnurl_auth_status {
  pending
  done
}

model discord_users {
  id           String @id
  discord_name String
  user_id      BigInt
  users        users  @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "fk dc_users.users")
}

model ln_users {
  id          BigInt       @id(map: "users_pkey") @default(autoincrement())
  ln_key      String?
  user_id     BigInt?
  users       users?       @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "ln_users_users_id_fk")
  lnurl_auths lnurl_auth[]
}

model password_users {
  id       BigInt @id @default(autoincrement())
  username String @unique
  password String
  user_id  BigInt
  users    users  @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model users {
  id             BigInt           @id(map: "users_pkey1") @default(autoincrement())
  pseudo         String?
  created_at     DateTime         @default(now()) @db.Date
  discord_users  discord_users[]
  ln_users       ln_users[]
  password_users password_users[]
  refresh_tokens refresh_tokens[]
}

model lnurl_auth {
  k1         String            @id
  status     lnurl_auth_status @default(pending)
  created_at DateTime?         @default(now()) @db.Timestamp(6)
  user_id    BigInt?
  lnUsers    ln_users?         @relation(fields: [user_id], references: [id], onDelete: Cascade, map: "ln_users_lnurl_auth_fk")
}

model refresh_tokens {
  id         BigInt    @id @default(autoincrement())
  token_hash String    @unique
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  revoked_at DateTime? @db.Timestamp(6)
  user_id    BigInt
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
